// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== CORE MODELS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Onboarding state
  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(0)  // Track progress (0-3)

  // Subscription
  subscriptionTier    String  @default("free")  // free, premium
  subscriptionStatus  String?
  stripeCustomerId    String? @unique

  // Retention metrics
  lastLoginAt         DateTime?
  loginStreak         Int      @default(0)
  longestLoginStreak  Int      @default(0)
  totalLogins         Int      @default(0)

  totalPoints         Int      @default(0)
  currentLevel        Int      @default(1)

  // Relationships
  profile             Profile?
  roadmaps            Roadmap[]
  tasks               Task[]
  achievements        UserAchievement[]
  notificationPrefs   NotificationPreference?
  activityLog         ActivityLog[]

  accounts            Account[]
  sessions            Session[]

  @@index([email])
  @@index([lastLoginAt])
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Demographics (Step 1)
  gradeLevel       String?   // "9", "10", "11", "12"
  graduationYear   Int?
  location         String?   // City, State

  // Academics (Step 2)
  gpa              Float?
  gpaScale         Float?    @default(4.0)
  satScore         Int?
  actScore         Int?
  apCourses        String[]  // Array of AP courses
  honors           String[]

  // Extracurriculars (Step 3)
  extracurriculars Json?     // Structured data: [{ name, role, years, hours }]
  leadership       String[]
  awards           String[]

  // Interests & Goals
  intendedMajors   String[]
  careerInterests  String[]
  collegePreferences Json?   // { size, location, setting, affordability }

  // Essay/personal
  personalStatement String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Roadmap {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String   // "Your College Application Roadmap"
  description String?  @db.Text

  // AI-generated content
  generatedBy String   @default("claude")  // AI model used
  generatedAt DateTime @default(now())

  // Versioning (when user regenerates)
  version     Int      @default(1)
  isActive    Boolean  @default(true)

  // Structure
  phases      Phase[]  // Timeline phases

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, isActive])
}

model Phase {
  id          String   @id @default(cuid())
  roadmapId   String
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  title       String   // "Junior Year Fall", "Summer Before Senior Year"
  description String?  @db.Text

  startDate   DateTime?
  endDate     DateTime?

  order       Int      // Display order

  tasks       Task[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([roadmapId])
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  phaseId     String?
  phase       Phase?    @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  title       String
  description String?   @db.Text

  // Categorization
  category    String    // "testing", "essays", "research", "applications", "financial_aid"
  priority    String    @default("medium")  // "low", "medium", "high", "urgent"

  // Scheduling
  dueDate     DateTime?
  startDate   DateTime?

  // Completion
  status      String    @default("pending")  // "pending", "in_progress", "completed", "skipped"
  completedAt DateTime?

  // Retention mechanics
  isQuickWin  Boolean   @default(false)  // Can be done in <15 min
  pointsValue Int       @default(10)      // Points awarded on completion

  // AI context
  aiGenerated Boolean   @default(false)

  // Order within phase
  order       Int       @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([phaseId])
}

// ==================== RETENTION MODELS ====================

model Achievement {
  id          String   @id @default(cuid())

  key         String   @unique  // "first_login", "completed_10_tasks", "7_day_streak"
  name        String
  description String
  icon        String?

  category    String   // "onboarding", "tasks", "streaks", "milestones"
  pointsValue Int      @default(0)
  tier        String   @default("bronze")  // bronze, silver, gold, platinum

  // Unlock criteria (JSON for flexibility)
  criteria    Json     // { type: "task_count", value: 10 }

  users       UserAchievement[]

  createdAt   DateTime @default(now())
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  unlockedAt    DateTime @default(now())
  viewed        Boolean  @default(false)  // Show celebration modal

  @@unique([userId, achievementId])
  @@index([userId])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email notifications
  emailEnabled          Boolean @default(true)
  dailyDigest           Boolean @default(true)
  weeklyInsights        Boolean @default(true)
  deadlineReminders     Boolean @default(true)
  milestoneNotifications Boolean @default(true)

  // Timing preferences
  preferredTimeOfDay    String  @default("morning")  // morning, afternoon, evening

  // Push notifications (future)
  pushEnabled           Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyInsight {
  id          String   @id @default(cuid())

  // Global insights sent to all active users
  weekStarting DateTime

  title       String
  content     String   @db.Text
  category    String   // "tip", "college_spotlight", "deadline_reminder", "strategy"

  // AI-generated
  generatedBy String   @default("claude")
  generatedAt DateTime @default(now())

  // Personalization (future)
  targetAudience Json?  // { gradeLevel: "11", intendedMajor: "engineering" }

  createdAt   DateTime @default(now())

  @@unique([weekStarting, category])
  @@index([weekStarting])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  eventType   String   // "login", "task_completed", "profile_updated", "roadmap_generated"
  eventData   Json?    // Additional context

  pointsAwarded Int?   // Points earned from this action

  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventType])
}

// ==================== AUTH MODELS (NextAuth) ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
